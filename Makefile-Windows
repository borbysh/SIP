# Makefile for heat_omp project (Microsoft Visual Studio)
# Usage: nmake -f Makefile.win
#        nmake -f Makefile.win COMP=msvc
#        nmake -f Makefile.win clean

!IF "$(COMP)" == ""
COMP=msvc
!ENDIF

COMMONDIR = d:\Treasure\Heat_eq_solver\common
!IF "$(COMP)" == "msvc"
CC=cl
CCFLAGS=/O2 /W4 /I$(COMMONDIR)
LDFLAGS=/LIBPATH:"c:\Users\aless\vcpkg\installed\x64-windows\lib"
LIBS = libpng16.lib z.lib
EXE_EXT=.exe
OBJ_EXT=.obj
!ENDIF

!IF "$(COMP)" == "gnu"
CC=gcc
CCFLAGS=-fopenmp -O3 -Wall -I$(COMMONDIR)
LDFLAGS=
LIBS=-lpng
EXE_EXT=
OBJ_EXT=.o
!ENDIF

EXE=heat_omp$(EXE_EXT)
OBJS=core$(OBJ_EXT) setup$(OBJ_EXT) utilities$(OBJ_EXT) io$(OBJ_EXT) main$(OBJ_EXT)
OBJS_PNG=$(COMMONDIR)\pngwriter$(OBJ_EXT)

all: $(EXE)

$(EXE): $(OBJS) $(OBJS_PNG)
	$(CC) $(CCFLAGS) $(OBJS) $(OBJS_PNG) /Fe$@ $(LDFLAGS) $(LIBS)

.c$(OBJ_EXT):
	$(CC) $(CCFLAGS) /c $<

clean:
	-del $(EXE) *.$(OBJ_EXT) $(COMMONDIR)\*.$(OBJ_EXT) *.png
	@echo Clean completed
